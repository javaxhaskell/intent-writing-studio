# ===== intent-writing-studio environment =====
# Copy to .env.local and fill in. Never commit real values.

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PROJECT_REF=

# --- Supabase (SERVER-ONLY — never expose to the browser bundle) ---
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
# CLI/Management API token, used by tooling only (migrations, branching)
SUPABASE_ACCESS_TOKEN=

# --- Foundation model (SERVER-ONLY) ---
# One frozen model per project; see docs/decisions/ for the pinning ADR.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=

# --- Upstream DocFlow legacy vars (frontend expects these today; being
#     replaced by the Supabase backend during Milestones 1-3) ---
NEXT_PUBLIC_SERVER_URL=
NEXT_PUBLIC_WEBSOCKET_URL=
NEXT_PUBLIC_NOTIFICATION_WEBSOCKET_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional observability (absent values must not block boot) ---
NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=
NEXT_PUBLIC_DATADOG_SITE=
