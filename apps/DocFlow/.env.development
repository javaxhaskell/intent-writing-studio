# Development defaults — local services only. Never point these at third-party
# infrastructure. Real values (Supabase, model keys) live in the gitignored
# .env.local; see /.env.example for the full variable list.

NEXT_PUBLIC_SERVER_URL = http://localhost:8080

NEXT_PUBLIC_AUTH_LOGIN_URL = http://localhost:8080/api/v1/auth/github

NEXT_PUBLIC_WEBSOCKET_URL = ws://localhost:8080/collaboration

NEXT_PUBLIC_NOTIFICATION_WEBSOCKET_URL = http://localhost:8080

NEXT_PUBLIC_SITE_URL = http://localhost:3000
